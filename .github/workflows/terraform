name: terraform-multi-env-10

on:
  push:
    branches: [dev, qa, prod]
  workflow_dispatch:

jobs:
  deploy:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v3

      # 🔥 Set env based on branch
      - name: Set Environment
        run: |
          if [[ "${GITHUB_REF_NAME}" == "dev" ]]; then
            echo "ENV=dev" >> $GITHUB_ENV
            echo "AWS_REGION=ap-south-1" >> $GITHUB_ENV
          elif [[ "${GITHUB_REF_NAME}" == "qa" ]]; then
            echo "ENV=qa" >> $GITHUB_ENV
            echo "AWS_REGION=us-east-1" >> $GITHUB_ENV
          elif [[ "${GITHUB_REF_NAME}" == "main" ]]; then
            echo "ENV=prod" >> $GITHUB_ENV
            echo "AWS_REGION=eu-west-1" >> $GITHUB_ENV
          fi

      - name: Setup Terraform
        uses: hashicorp/setup-terraform@v3

      - name: Configure AWS
        uses: aws-actions/configure-aws-credentials@v2
        with:
          aws-access-key-id: ${{ secrets.AWS_ACCESS_KEY_ID }}
          aws-secret-access-key: ${{ secrets.AWS_SECRET_KEY_ID}}
          aws-region: ${{ env.AWS_REGION }}

      - name: Terraform Init
        run: |
          terraform init \
            -backend-config="bucket=terraform-bucket-prabhjot" \
            -backend-config="key=${{ env.ENV }}/terraform.tfstate" \
            -backend-config="region=ap-south-1"
        working-directory: environments/${{ env.ENV }}

      - name: Terraform Validate
        run: terraform validate
        working-directory: environments/${{ env.ENV }}

      - name: Terraform Plan
        run: terraform plan -out=tfplan
        working-directory: environments/${{ env.ENV }}

      - name: Terraform Apply
        run: terraform apply -auto-approve tfplan
        working-directory: environments/${{ env.ENV }}
